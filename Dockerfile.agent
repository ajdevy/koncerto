FROM eclipse-temurin:21-jre-alpine

RUN apk add --no-cache \
    git \
    gradle \
    bash \
    curl \
    wget \
    openssh-client \
    docker-cli \
    github-cli \
    nodejs \
    npm \
    socat

RUN npm install -g @openai/codex @anthropic-ai/claude-code

WORKDIR /workspace

CMD ["sleep", "infinity"]
